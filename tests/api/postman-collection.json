    {
      "name": "Notes",
      "description": "CRUD заметок (требует авторизации)",
      "item": [
        {
          "name": "Create Note",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test(\"Response has note fields\", function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property(\"id\");",
                  "    pm.expect(json).to.have.property(\"title\");",
                  "    pm.expect(json).to.have.property(\"text\");",
                  "    pm.expect(json.title).to.eql(\"Test Note\");",
                  "    pm.environment.set(\"noteId\", json.id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "if (!pm.environment.get(\"token\")) {",
                  "    var loginUrl = pm.variables.get(\"baseUrl\") + \"/login/\";",
                  "    var payload = {",
                  "        username: pm.variables.get(\"testUsername\"),",
                  "        password: pm.variables.get(\"testPassword\")",
                  "    };",
                  "    pm.sendRequest({",
                  "        url: loginUrl,",
                  "        method: 'POST',",
                  "        header: { 'Content-Type': 'application/json' },",
                  "        body: { mode: 'raw', raw: JSON.stringify(payload) }",
                  "    }, function (err, res) {",
                  "        if (!err && res.code === 200) {",
                  "            var json = res.json();",
                  "            pm.environment.set(\"token\", json.token);",
                  "        }",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Token {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Test Note\",\n  \"text\": \"This is a test note created by CI pipeline\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/notes/",
              "host": ["{{baseUrl}}"],
              "path": ["notes"]
            }
          },
          "response": []
        },
        {
          "name": "Get Notes List",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response is array\", function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.be.an(\"array\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Token {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/notes/",
              "host": ["{{baseUrl}}"],
              "path": ["notes"]
            }
          },
          "response": []
        },
        {
          "name": "Update Note",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Title is updated\", function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.title).to.eql(\"Updated Test Note\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Token {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Test Note\",\n  \"text\": \"This note has been updated by CI pipeline\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/notes/{{noteId}}/",
              "host": ["{{baseUrl}}"],
              "path": ["notes", "{{noteId}}"]
            }
          },
          "response": []
        },
        {
          "name": "Delete Note",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 204\", function () {",
                  "    pm.response.to.have.status(204);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Token {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/notes/{{noteId}}/",
              "host": ["{{baseUrl}}"],
              "path": ["notes", "{{noteId}}"]
            }
          },
          "response": []
        },
        {
          "name": "Notes No Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 401\", function () {",
                  "    pm.response.to.have.status(401);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/notes/",
              "host": ["{{baseUrl}}"],
              "path": ["notes"]
            }
          },
          "response": []
        }
      ]
